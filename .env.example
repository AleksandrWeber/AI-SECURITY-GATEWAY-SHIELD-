NODE_ENV=development
PORT=3001

# SQLite (local dev default)
DATABASE_URL=file:./data/shield.db

# PostgreSQL (Docker / production) — uncomment to use locally:
# DATABASE_URL=postgresql://shield:shield@localhost:5432/shield

PRIVACY_MODE=true
DEMO_MODE=false
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
LOG_LEVEL=info
AI_CONFIDENCE_THRESHOLD=70
MAX_PROMPT_LENGTH=32000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
RULES_VERSION=1.1.0
CORS_ORIGIN=http://localhost:5173

# Batch analyze (V2.2)
BATCH_MAX_ITEMS=50
BATCH_CONCURRENCY=5

# Webhooks (V2.4)
WEBHOOKS_ENABLED=true
WEBHOOK_MAX_RETRIES=3
WEBHOOK_TIMEOUT_MS=5000
WEBHOOK_MAX_SUBSCRIPTIONS=20

# AI rule suggestions (V2.5)
KNOWLEDGE_DIR=./knowledge
RULE_SUGGESTIONS_ENABLED=true
AUTO_SUGGEST_RULES=true
MAX_PENDING_SUGGESTIONS=100

# Database rules (V3.1)
RULES_DB_ENABLED=true

# Teams / enterprise (V3.6)
TEAMS_ENABLED=false
TEAM_ADMIN_KEY=

# MCP server (V3.3) — optional, for Cursor / Claude Desktop
# SHIELD_MCP_MODE=local
# SHIELD_MCP_MODE=remote
# SHIELD_MCP_DEMO=false

# CLI (V2.6) — optional remote mode
# SHIELD_API_URL=http://localhost:3001
# SHIELD_API_KEY=
# SHIELD_FORCE_REMOTE=false

# API key auth (V1.5)
API_KEY_REQUIRED=false
API_KEYS=
