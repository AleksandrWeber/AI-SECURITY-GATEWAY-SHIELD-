NODE_ENV=development
PORT=3001

# SQLite (local dev default)
DATABASE_URL=file:./data/shield.db

# PostgreSQL (Docker / production) — uncomment to use locally:
# DATABASE_URL=postgresql://shield:shield@localhost:5432/shield

PRIVACY_MODE=true
DEMO_MODE=false
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
LOG_LEVEL=info
AI_CONFIDENCE_THRESHOLD=70
MAX_PROMPT_LENGTH=32000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
RULES_VERSION=1.0.0
CORS_ORIGIN=http://localhost:5173

# Batch analyze (V2.2)
BATCH_MAX_ITEMS=50
BATCH_CONCURRENCY=5

# API key auth (V1.5)
API_KEY_REQUIRED=false
API_KEYS=
