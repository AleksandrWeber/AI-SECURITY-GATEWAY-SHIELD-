{
  "version": "1.0.0",
  "category": "tool_abuse",
  "rules": [
    {
      "id": "ta-001",
      "name": "Execute shell command",
      "category": "tool_abuse",
      "language": ["en", "universal"],
      "severity": "HIGH",
      "type": "regex",
      "pattern": "(run|execute)\\s+(shell|bash|cmd|powershell)",
      "confidenceBoost": 40,
      "enabled": true,
      "source": "owasp-llm05"
    },
    {
      "id": "ta-002",
      "name": "Delete all files",
